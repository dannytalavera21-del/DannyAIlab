NODE_ENV=development
PORT=3002

# Nunca copie secretos reales en Git.
# VERIFY_TOKEN lo elige el propietario.
VERIFY_TOKEN=replace_with_private_verify_token
# WHATSAPP_TOKEN lo entrega Meta.
WHATSAPP_TOKEN=replace_with_whatsapp_access_token
# META_APP_SECRET se obtiene en la configuración de la app de Meta.
META_APP_SECRET=replace_with_meta_app_secret
PHONE_NUMBER_ID=replace_with_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=replace_with_business_account_id
GRAPH_API_VERSION=v25.0

DEFAULT_ORGANIZATION_ID=org-daniel-rentals
DEFAULT_BUSINESS_UNIT_ID=business-unit-main
PRODUCT_ID=olive-rentals

PROCESSED_MESSAGE_TTL_MINUTES=60
SESSION_TTL_MINUTES=30
